# ── Google AI ─────────────────────────────────────────────────────────────────
# Your Google AI Studio API key (https://aistudio.google.com/apikey)
GOOGLE_API_KEY=your_google_ai_api_key_here

# ── Google Cloud / Vertex AI (needed for Veo + Gemini Image Preview) ──────────
GOOGLE_CLOUD_PROJECT=your_gcp_project_id
GOOGLE_CLOUD_LOCATION=us-central1

# ── Firebase ──────────────────────────────────────────────────────────────────
# Path to your Firebase service account key JSON file.
# Default: serviceAccountKey.json (place it in the project root)
FIREBASE_SA_KEY=serviceAccountKey.json

# Your Firebase Realtime Database URL
# Format: https://<project-id>-default-rtdb.firebaseio.com
FIREBASE_DATABASE_URL=https://e-book-21589-default-rtdb.firebaseio.com
